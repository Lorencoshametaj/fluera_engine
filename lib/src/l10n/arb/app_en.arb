  "socraticInfo_title": "Socratic Method",
  "socraticInfo_heroTitle": "The Socratic Interrogation",
  "socraticInfo_heroBody": "Fluera analyzes your handwritten notes and generates questions calibrated to your zone of proximal development (ZPD). It doesn't give you answers — it guides you to find them yourself.",
  "socraticInfo_whyItWorks": "The cognitive value lies in the ATTEMPT at retrieval, not in the correct answer. Even a high-confidence error (hypercorrection) is a powerful learning moment.",
  "socraticInfo_howItWorks": "How it works",
  "socraticInfo_typeLacunaTitle": "Gap",
  "socraticInfo_typeLacunaSubtitle": "Recall 1-2",
  "socraticInfo_typeLacunaBody": "Creates a \"cognitive gap\" you feel the need to fill. Asks what CONNECTS two concepts or what's MISSING.",
  "socraticInfo_typeLacunaPrinciple": "Zeigarnik Effect + Active Recall",
  "socraticInfo_typeChallengeTitle": "Challenge",
  "socraticInfo_typeChallengeSubtitle": "Recall 3",
  "socraticInfo_typeChallengeBody": "Presents a counterexample to challenge you. Forces you to DEFEND or REVISE your understanding.",
  "socraticInfo_typeChallengePrinciple": "Desirable Difficulties (Bjork)",
  "socraticInfo_typeDepthTitle": "Depth",
  "socraticInfo_typeDepthSubtitle": "Recall 4",
  "socraticInfo_typeDepthBody": "Asks for the MECHANISM, the CAUSE, the PRINCIPLE. Shifts from shallow to deep encoding.",
  "socraticInfo_typeDepthPrinciple": "Levels of Processing (Craik & Lockhart)",
  "socraticInfo_typeTransferTitle": "Transfer",
  "socraticInfo_typeTransferSubtitle": "Recall 5",
  "socraticInfo_typeTransferBody": "Analogies with OTHER subjects or applications in NEW contexts. Creates bridges between domains to consolidate knowledge.",
  "socraticInfo_typeTransferPrinciple": "Transfer Learning + Interleaving",
  "socraticInfo_tryConfidence": "Try the Confidence Scale",
  "socraticInfo_spacedRepetition": "Spaced Repetition (FSRS)",
  "socraticInfo_feedbackMatrix": "Feedback Matrix",
  "socraticInfo_references": "Based on research by Butterfield & Metcalfe (2001),\nBjork (1994), Craik & Lockhart (1972), Vygotsky (1978)",
  "socraticInfo_flowStep1Title": "Write",
  "socraticInfo_flowStep1Body": "Take handwritten notes on the canvas",
  "socraticInfo_flowStep2Title": "Analysis",
  "socraticInfo_flowStep2Body": "Fluera recognizes the text (OCR) and identifies the subject",
  "socraticInfo_flowStep3Title": "Question",
  "socraticInfo_flowStep3Body": "A bubble appears with the Socratic question",
  "socraticInfo_flowStep4Title": "Confidence",
  "socraticInfo_flowStep4Body": "You declare how confident you are (1-5)",
  "socraticInfo_flowStep5Title": "Retrieval",
  "socraticInfo_flowStep5Body": "You think about the answer mentally",
  "socraticInfo_flowStep6Title": "Self-evaluation",
  "socraticInfo_flowStep6Body": "You declare whether you knew or didn't know",
  "socraticInfo_flowStep7Title": "Feedback",
  "socraticInfo_flowStep7Body": "Personalized insight + FSRS updated",
  "socraticInfo_breadcrumbIntro": "If you're stuck, you can ask for up to 3 progressive hints that guide without revealing:",
  "socraticInfo_breadcrumb1Title": "🌫️ The Distant Echo",
  "socraticInfo_breadcrumb1Body": "Vague direction — activates semantic priming",
  "socraticInfo_breadcrumb2Title": "🛤️ The Path",
  "socraticInfo_breadcrumb2Body": "Narrows the domain — reduces the search space",
  "socraticInfo_breadcrumb3Title": "🚪 The Threshold",
  "socraticInfo_breadcrumb3Body": "Final scaffolding — the answer is one step away",
  "socraticInfo_breadcrumbNote": "The answer is NEVER revealed — not even at level 3.",
