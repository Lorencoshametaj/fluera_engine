  "flueraMethodInfo_title": "The Fluera Method",
  "flueraMethodInfo_heroTitle": "Cognitive Loop",
  "flueraMethodInfo_heroBody": "4 phases, 12 steps, one science: turning notes into learning that lasts.",
  "flueraMethodInfo_whyItWorks": "Every step is a cognitive mechanism proven in the lab.",
  "flueraMethodInfo_phasesTitle": "The 4 phases of the Loop",
  "flueraMethodInfo_scienceTitle": "The science behind Fluera",
  "flueraMethodInfo_phase1Title": "CAPTURE",
  "flueraMethodInfo_phase1Subtitle": "Turn lectures into active traces",
  "flueraMethodInfo_phase2Title": "GENERATE",
  "flueraMethodInfo_phase2Subtitle": "Force your mind to reconstruct",
  "flueraMethodInfo_phase3Title": "CONSOLIDATE",
  "flueraMethodInfo_phase3Subtitle": "Let time cement memory",
  "flueraMethodInfo_phase4Title": "TRANSFER",
  "flueraMethodInfo_phase4Subtitle": "Connect and apply beyond context",
  "flueraMethodInfo_tapToExpand": "Tap for steps",
  "flueraMethodInfo_step1Title": "Handwritten capture",
  "flueraMethodInfo_step1Body": "Write on the canvas during the lecture. The pen activates motor and spatial channels the keyboard cannot reach.",
  "flueraMethodInfo_step1Citation": "Mueller & Oppenheimer, 2014",
  "flueraMethodInfo_step2Title": "Blind reconstruction",
  "flueraMethodInfo_step2Body": "Within 2 hours reopen the canvas in an empty zone. Rewrite without looking at your notes. Gaps are valuable information.",
  "flueraMethodInfo_step2Citation": "Slamecka & Graf, 1978 — Generation Effect",
  "flueraMethodInfo_step3Title": "Socratic interrogation",
  "flueraMethodInfo_step3Body": "Set your confidence before answering. The AI asks questions, never gives answers. The most powerful metacognitive exercise.",
  "flueraMethodInfo_step3Citation": "Roediger & Karpicke, 2006 — Test Effect",
  "flueraMethodInfo_step4Title": "Centaur Comparison",
  "flueraMethodInfo_step4Body": "Discover which fragments to integrate. Errors made with high confidence imprint 3 times more deeply.",
  "flueraMethodInfo_step4Citation": "Butterfield & Metcalfe, 2001 — Hypercorrection",
  "flueraMethodInfo_step5Title": "Sleep (7-8 hours)",
  "flueraMethodInfo_step5Body": "Consolidation happens while you sleep. Without deep sleep, Steps 1-4 vanish in a few days.",
  "flueraMethodInfo_step5Citation": "Walker, 2017 — Sleep & Memory Consolidation",
  "flueraMethodInfo_step6Title": "First return at 24h",
  "flueraMethodInfo_step6Body": "Fluera blurs nodes proportionally to your confidence. An audio cue from the professor appears as a hint.",
  "flueraMethodInfo_step6Citation": "Ebbinghaus, 1885 — Forgetting Curve",
  "flueraMethodInfo_step7Title": "Solidale Learning",
  "flueraMethodInfo_step7Body": "Teaching a peer is the fastest way to discover what you don't really know. Canvas visits, recall duels.",
  "flueraMethodInfo_step7Citation": "Chase et al., 2009 — Protégé Effect",
  "flueraMethodInfo_step8Title": "Adaptive review (3, 7, 14, 30+ days)",
  "flueraMethodInfo_step8Body": "Increasing intervals calibrated by FSRS-5. Subjects interleaved, not blocked: interleaving trains pattern recognition.",
  "flueraMethodInfo_step8Citation": "Rohrer & Taylor, 2007 — Interleaving",
  "flueraMethodInfo_step9Title": "Bridges across subjects",
  "flueraMethodInfo_step9Body": "Maximum zoom out. You draw the connections between different canvas zones. This is where knowledge applies to new contexts.",
  "flueraMethodInfo_step9Citation": "Perkins & Salomon, 1992 — Far Transfer",
  "flueraMethodInfo_step10Title": "Exam simulation",
  "flueraMethodInfo_step10Body": "Fog of War mode: rebuild an entire zone blind. The test that truly predicts how you'll perform.",
  "flueraMethodInfo_step10Citation": "Bjork, 1994 — Desirable Difficulties",
  "flueraMethodInfo_step11Title": "The exam",
  "flueraMethodInfo_step11Body": "The canvas is already in your head.",
  "flueraMethodInfo_step11Citation": "(external validation)",
  "flueraMethodInfo_step12Title": "Stays forever",
  "flueraMethodInfo_step12Body": "The canvas doesn't close at the end of the course. It grows with you, lecture after lecture, year after year. Temporal replay to relive how it grew.",
  "flueraMethodInfo_step12Citation": "Clark & Chalmers, 1998 — Extended Cognition",
  "flueraMethodInfo_proBadge": "Pro",
  "flueraMethodInfo_v15Badge": "Soon",
  "flueraMethodInfo_scienceFooter": "Based on 50+ years of research in cognitive psychology and learning neuroscience.",
  "flueraMethodInfo_learnMoreCta": "Discover Fluera",
  "flueraMethodInfo_offlineError": "Couldn't open browser. Visit fluera.dev",
  "flueraMethodInfo_settingsTile": "The Fluera Method",
